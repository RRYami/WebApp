# Pricing Platform Environment Configuration
# Copy this file to .env at the project root and fill in your real API keys.
# DO NOT commit .env to version control.

# Database
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/pricing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pricing

# API Keys
FRED_API_KEY=your_fred_api_key_here
DATABENTO_API_KEY=your_databento_api_key_here

# Logging
LOG_LEVEL=INFO
